---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 10);
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main { width: 720px; max-width: calc(100% - 2em); margin: auto; padding: 1em; }
			.hero { margin: 2em 0 3em; }
			.hero h1 { font-size: 2em; margin-bottom: 0.3em; }
			.hero p { color: rgb(var(--gray)); }
			ul { list-style: none; padding: 0; }
			li { border-bottom: 1px solid rgb(var(--gray-light)); padding: 1.2em 0; }
			li:last-child { border-bottom: none; }
			.post-link { text-decoration: none; color: inherit; display: block; }
			.post-link:hover h2 { color: rgb(var(--accent)); }
			h2 { margin: 0 0 0.3em; font-size: 1.25em; line-height: 1.3; }
			.description { margin: 0 0 0.5em; color: rgb(var(--gray-dark)); font-size: 0.95em; }
			.meta { display: flex; align-items: center; gap: 0.8em; flex-wrap: wrap; }
			.date { color: rgb(var(--gray)); font-size: 0.85em; }
			.tags { display: flex; gap: 0.4em; flex-wrap: wrap; }
			.tag {
				background: rgb(var(--accent-light)); color: rgb(var(--accent-dark));
				padding: 0.1em 0.6em; border-radius: 999px; font-size: 0.8em;
				text-decoration: none;
			}
			.tag:hover { background: rgb(var(--accent)); color: white; }
			.all-posts { display: block; text-align: center; margin-top: 2em; color: rgb(var(--accent)); }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>junbit.dev</h1>
				<p>AI 모델을 활용한 개발 실험과 프로젝트 빌드로그</p>
			</div>
			<ul>
				{posts.map((post) => (
					<li>
						<a class="post-link" href={`/blog/${post.id}/`}>
							<h2>{post.data.title}</h2>
							{post.data.description && <p class="description">{post.data.description}</p>}
						</a>
						<div class="meta">
							<span class="date"><FormattedDate date={post.data.pubDate} /></span>
							{post.data.tags.length > 0 && (
								<div class="tags">
									{post.data.tags.map(tag => (
										<a class="tag" href={`/tags/${tag}`}>#{tag}</a>
									))}
								</div>
							)}
						</div>
					</li>
				))}
			</ul>
			<a class="all-posts" href="/blog/">모든 포스트 보기 →</a>
		</main>
		<Footer />
	</body>
</html>
